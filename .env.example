# Shopify API
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_API_SCOPES=write_products,read_products,write_orders,read_orders,write_customers,read_customers

# App Configuration
APP_URL=https://your-app-url.vercel.app
APP_ENV=development
SESSION_SECRET=your_session_secret_here_min_32_chars

# Database
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/smartstack
# SQLite (dev):
# DATABASE_URL="file:./dev.db"  # also change provider in prisma/schema.prisma

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key

# Optional: Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX
