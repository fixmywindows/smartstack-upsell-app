{
  "name": "smartstack",
  "version": "0.1.0",
  "description": "Flexible Shopify upsell/cross-sell app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "node ./build/index.js",
    "preview": "remix vite:build && node ./build/index.js",
    "typecheck": "tsc",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "lint": "eslint app",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@remix-run/express": "^2.8.1",
    "@remix-run/node": "^2.8.1",
    "@remix-run/react": "^2.8.1",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.4",
    "express": "^4.19.2",
    "morgan": "^1.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@prisma/client": "^5.9.1",
    "@remix-run/css-bundle": "^2.8.1",
    "@remix-run/dev": "^2.8.1",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "prisma": "^5.9.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.1",
    "vite-tsconfig-paths": "^4.2.0"
  },
  "engines": {
    "node": "18.x || 20.x"
  }
}
